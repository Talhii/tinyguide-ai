# TinyGuide AI — backend environment template.
# Copy to `.env` and fill in. Do NOT commit the real .env.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS (comma-separated). The Next.js dev server defaults to :3000.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Supabase (optional — data persists when set; in-memory fallback otherwise).
# SUPABASE_KEY must be the SERVICE ROLE key (server-side only — never expose it
# to the browser). Run backend/supabase_schema.sql once in the SQL editor.
SUPABASE_URL=
SUPABASE_KEY=

# Groq (free, no credit card — get a key at console.groq.com).
# When set, the assistant uses Groq for live answers.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic / Claude (optional, paid). Used only if GROQ_API_KEY is empty.
# Without any key, the assistant returns a labelled stub.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
